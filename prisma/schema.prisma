generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum LomasVards {
  LIETOTAJS
  ADMIN
}

model Lietotajs {
  id       Int          @id @default(autoincrement())
  email    String       @unique
  pwd      String
  vards     String?
  loma     LomasVards @default(LIETOTAJS)
  zanrss   LietotajsZanrs[]
  anime    LietotajsAnime[]
}

model Zanrs {
  id       Int          @id @default(autoincrement())
  vards     String       @unique
  lietotajss    LietotajsZanrs[]
}

model LietotajsZanrs {
  lietotajsId   Int
  zanrsId  Int
  smagums   Int        @default(1)

  lietotajs     Lietotajs   @relation(fields: [lietotajsId], references: [id])
  zanrs    Zanrs  @relation(fields: [zanrsId], references: [id])

  @@id([lietotajsId, zanrsId])
}

model LietotajsAnime {
  lietotajsId   Int
  animeId  Int
  patik    Boolean
  izveidots DateTime @default(now())

  lietotajs     Lietotajs  @relation(fields: [lietotajsId], references: [id])

  @@id([lietotajsId, animeId])
}

model Anime {
  id        Int    @id
  title     String
  synopsis  String?
  images    Json?
  zanrss    Json?
  fetchedAt DateTime @default(now())

  @@map("anime")
}

